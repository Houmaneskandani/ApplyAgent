# ─── Application mode ──────────────────────────────────────────────
# "production" enables strict validation (crashes if required vars are missing).
APP_ENV=development

# ─── Required everywhere ───────────────────────────────────────────
# Supabase → Settings → Database → URI (Transaction mode, port 5432).
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Strong random — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# MUST NOT be the literal "your-secret-key-change-this".
SECRET_KEY=

# Fernet key for encrypting per-user secrets (Gmail App Passwords, etc) at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# Anthropic — required for scoring + form filling.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Required if Stripe is enabled ─────────────────────────────────
# If STRIPE_SECRET_KEY is set, STRIPE_WEBHOOK_SECRET is REQUIRED.
# Without the webhook secret, /credits/webhook accepts unsigned requests
# and anyone can grant themselves credits.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:5173

# ─── Required if the user uploads a resume ─────────────────────────
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# ─── Optional integrations ─────────────────────────────────────────
CAPSOLVER_API_KEY=
RAPIDAPI_KEY=

# Local CLI scripts only
USER_EMAIL=you@email.com
USER_NAME=Your Name
JOB_KEYWORDS=software engineer,backend
JOB_LOCATION=remote

# SMS / Email notifications (operator-only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Web service only — set to "1" if you do NOT run a separate worker service.
# Default 0 because railway.worker.toml already runs the scheduler.
RUN_SCHEDULER_IN_WEB=0

# Comma-separated extra frontends allowed to call this API (CORS).
ALLOWED_ORIGINS=

# ─── Bot resilience (Phase 2) ──────────────────────────────────────
# Per-domain throttle. Defaults are sane: max 2 in-flight applies per ATS
# host with a 15-60s jitter cooldown between same-host applies.
MAX_CONCURRENT_PER_DOMAIN=2
DOMAIN_JITTER_MIN_SEC=15
DOMAIN_JITTER_MAX_SEC=60

# Set to "1" to opt out of headless. Requires a display server (Xvfb)
# in Docker; gives the strongest anti-detection profile.
HEADED_BROWSER=0

# Where to persist BrowserContext storage_state (cookies/localStorage) per
# (user_id, ATS-domain). Reusing state on the next visit dramatically
# reduces the rate of first-visit Cloudflare / Akamai challenges.
STORAGE_STATE_DIR=/tmp/applyagent_storage_state

# Optional residential proxy. If set, every browser launch routes
# through this gateway. Use a single URL or a comma-separated pool.
#   PROXY_URL=http://user:pass@gateway.proxyprovider.com:8000
#   PROXY_URLS=http://u:p@h1:8000,http://u:p@h2:8000
PROXY_URL=
PROXY_URLS=

# ─── Observability (Phase 8) ───────────────────────────────────────
# Sentry — leave empty to disable. SDK init is a no-op without DSN.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Matcher concurrency ───────────────────────────────────────────
# How many jobs to score in parallel via Claude Haiku. 5 is conservative.
MATCHER_CONCURRENCY=5
