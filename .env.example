# ─── Application mode ──────────────────────────────────────────────
# "production" enables strict validation (crashes if required vars are missing).
APP_ENV=development

# ─── Required everywhere ───────────────────────────────────────────
# Supabase → Settings → Database → URI (Transaction mode, port 5432).
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Strong random — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# MUST NOT be the literal "your-secret-key-change-this".
SECRET_KEY=

# Fernet key for encrypting per-user secrets (Gmail App Passwords, etc) at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# Anthropic — required for scoring + form filling.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Required if Stripe is enabled ─────────────────────────────────
# If STRIPE_SECRET_KEY is set, STRIPE_WEBHOOK_SECRET is REQUIRED.
# Without the webhook secret, /credits/webhook accepts unsigned requests
# and anyone can grant themselves credits.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:5173

# ─── Required if the user uploads a resume ─────────────────────────
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# ─── Optional integrations ─────────────────────────────────────────
CAPSOLVER_API_KEY=
RAPIDAPI_KEY=

# Local CLI scripts only
USER_EMAIL=you@email.com
USER_NAME=Your Name
JOB_KEYWORDS=software engineer,backend
JOB_LOCATION=remote

# SMS / Email notifications (operator-only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Web service only — set to "1" if you do NOT run a separate worker service.
# Default 0 because railway.worker.toml already runs the scheduler.
RUN_SCHEDULER_IN_WEB=0

# Comma-separated extra frontends allowed to call this API (CORS).
ALLOWED_ORIGINS=
